  skos:prefLabel "Interlokale vereniging" ;
  skos:topConceptOf scheme:BestuurseenheidClassificatieCode ;
  skos:inScheme scheme:BestuurseenheidClassificatieCode , <http://lblod.data.gift/concept-schemes/10caf4a4-1ff5-4c05-917e-56489910d68b> .

<http://lblod.data.gift/concepts/b2133b86-24f0-44f0-9d10-5b4c7f944a9d>
  rdf:type ext:OrganizationClassificationCode , code:BestuurseenheidClassificatieCode ;
  mu:uuid "b2133b86-24f0-44f0-9d10-5b4c7f944a9d" ;
  skos:prefLabel "Vervoerregioraad" ;
  skos:altLabel "Vervoerregio" ; # Modelled as the werkingsgebied of a Vervoerregioraad, but colloquially known as a Vervoerregio.
  skos:topConceptOf scheme:BestuurseenheidClassificatieCode ;
  skos:inScheme scheme:BestuurseenheidClassificatieCode , <http://lblod.data.gift/concept-schemes/10caf4a4-1ff5-4c05-917e-56489910d68b> .

