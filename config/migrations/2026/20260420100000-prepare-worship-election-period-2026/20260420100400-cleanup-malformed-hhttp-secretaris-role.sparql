# Cleanup leftover `hhttp://` malformed Secretaris org:role triples introduced by
# the 2022 migrations `20220929092641-create-central-worship-organen-2023-2026.sparql`
# and `20220929104939-create-central-worship-organen-2026-2029.sparql` (line 31).
#
# By this point migration C (20260420100300) has already inserted the correct
# Secretaris `org:role` triple on the same mandate IRI, so removing the malformed
# one leaves each central-worship Secretaris mandate with exactly one valid role.

PREFIX org: <http://www.w3.org/ns/org#>

DELETE {
  GRAPH <http://mu.semte.ch/graphs/worship-service> {
    ?s org:role <hhttp://data.vlaanderen.be/id/concept/BestuursfunctieCode/e2af0ea1a6af96cfb698ac39ad985eea> .
  }
} WHERE {
  GRAPH <http://mu.semte.ch/graphs/worship-service> {
    ?s org:role <hhttp://data.vlaanderen.be/id/concept/BestuursfunctieCode/e2af0ea1a6af96cfb698ac39ad985eea> .
  }
}
